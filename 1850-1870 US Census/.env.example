# ==========================================
# FILE PATHS & DATA CONFIGURATION
# ==========================================
PROGRAM_DIR="C:\Genealogy"
RM_DIR="Roots Magic 11"
FTM_DIR="Family Tree Maker"
CSV_DIR="CSV\Generic_Project"
IMAGE_DIR="Media\1850-1870 US Census"
IMAGE_EXTENSION="jpg"
GEDCOM_OUTPUT_PATH="Gedcom\1850-1870 US Census"
GEDCOM_OUTPUT_NAME="1850 US Census - State - County.ged"
CSV_FILE="1850 US Census - State - County.csv"

# ==========================================
# ORGANIZATION & METADATA CONFIGURATION
# ==========================================
RESEARCHER="Your Name"
ORG_NAME="Your Genealogical Society"
SOFTWARE_NAME="RootsMagic"
SOFTWARE_VERS="11.0"
COPYRIGHT_START="2026"
GEDCOM_NOTE="This file contains original historical translations and research."
GEDCOM_CONC="Please do not upload this raw GEDCOM to public, collaborative trees without permission and attribution."
REVIEW_COLOR="1"
SUBM_ADDRESS="https://www.facebook.com/groups/your-group-id"
MGS_GROUP_URL="https://www.facebook.com/groups/your-group-id"
ANCESTRY_GROUP_URL="https://www.ancestry.com/groups/your-ancestry-group"

# ==========================================
# REPOSITORY & SOURCE IDs
# ==========================================
ROOT_SOURCE_ID="@S1@"
CALL_NUMBER="0000000"
REPOSITORY="Ancestry.com"
REPOSITORY_LOC="NARA - Washington, D.C., USA"
COLLECTION_URL="https://www.ancestry.com/search/collections/0000"
COLLECTION_NAME="1860 United States Federal Census, Ancestry.com"

# ==========================================
# CENSUS SCHEDULE CONFIGURATION (CENSUS)
# ==========================================
#Census Info
CENSUS_YEAR=1860
STATE="State Name"
COUNTY="County Name"
TOWNSHIP="City/Town/Township/Village Name"
FILM_NUMBER="00"
ROLL_NUMBER="M000"
CENSUS_PUBLISHER="Ancestry.com Operations, Inc."
CENSUS_PUB_LOC="Lehi, UT, USA"

# ==========================================
# ANCESTRY INFO EXTRACTION GUIDE
# Extract variables directly from the Ancestry image URL:
# Format:  .../collections/[APID_DB]/images/[ANCESTRY_IMAGE_BASE_ID]_[xxx]?pId=[ANCESTRY_START_RECORD_ID]
# Example: .../collections/7667/images/4211353_00094?pId=17613849
#   -> APID_DB = 7667
#   -> ANCESTRY_IMAGE_BASE_ID = 4211353
#   -> ANCESTRY_START_RECORD_ID = 17613849
# ==========================================
#Ancestry Info
ANCESTRY_START_RECORD_ID="00000000"
APID_DB="0000"
ANCESTRY_IMAGE_BASE_ID="0000000"

#Switches
MIN_MARRIAGE_AGE=12
MAX_SPOUSE_AGE_GAP=25
HUSBAND_CHILD_AGE_GAP_MIN=14
HUSBAND_CHILD_AGE_GAP_MAX=60
WIFE_CHILD_AGE_GAP_MIN=12
WIFE_CHILD_AGE_GAP_MAX=50